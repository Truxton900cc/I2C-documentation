// Inicialización estándar del LCD Hitachi HD44780 por I2C
void LCD_Init(void) {
    // Secuencia de inicialización para modo 4 bits
    __delay_ms(15);
    LCD_Cmd(0x03);
    __delay_ms(5);
    LCD_Cmd(0x03);
    __delay_us(150);
    LCD_Cmd(0x03);
    
    LCD_Cmd(0x02); // Establece modo de 4 bits
    
    LCD_Cmd(0x28); // Configuración: 2 líneas, matriz 5x8
    LCD_Cmd(0x0C); // Display ON, Cursor OFF, Parpadeo OFF
    LCD_Cmd(0x06); // Modo de entrada: Incrementar cursor automaticamente
    LCD_Cmd(0x01); // Limpiar pantalla
    __delay_ms(2);
}

// Envía un comando al LCD (RS = 0)
void LCD_Cmd(uint8_t cmd) {
    uint8_t alta, baja;
    alta = (cmd & 0xF0);        // Nos quedamos con los 4 bits altos
    baja = ((cmd << 4) & 0xF0); // Nos quedamos con los 4 bits bajos
    
    // Enviar nibble alto con pulso en Enable (Bit 2)
    I2C_Write_Byte(alta | BACKLIGHT | 0x04); // EN = 1, RS = 0
    __delay_us(1);
    I2C_Write_Byte(alta | BACKLIGHT);        // EN = 0, RS = 0
    
    // Enviar nibble bajo con pulso en Enable (Bit 2)
    I2C_Write_Byte(baja | BACKLIGHT | 0x04); // EN = 1, RS = 0
    __delay_us(1);
    I2C_Write_Byte(baja | BACKLIGHT);        // EN = 0, RS = 0
    
    __delay_ms(2);
}

// Envía un carácter de texto al LCD (RS = 1)
void LCD_Char(char data) {
    uint8_t alta, baja;
    alta = (data & 0xF0);        // 4 bits altos
    baja = ((data << 4) & 0xF0); // 4 bits bajos
    
    // Enviar nibble alto (RS = 1 -> Bit 0 en alto)
    I2C_Write_Byte(alta | BACKLIGHT | 0x05); // EN = 1, RS = 1
    __delay_us(1);
    I2C_Write_Byte(alta | BACKLIGHT | 0x01); // EN = 0, RS = 1
    
    // Enviar nibble bajo (RS = 1 -> Bit 0 en alto)
    I2C_Write_Byte(baja | BACKLIGHT | 0x05); // EN = 1, RS = 1
    __delay_us(1);
    I2C_Write_Byte(baja | BACKLIGHT | 0x01); // EN = 0, RS = 1
    
    __delay_us(50);
}
